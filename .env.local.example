NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Safe Exam Browser enforcement (optional)
# Set SEB_ENFORCE=true and paste the Browser Exam Key from SEB
# Configuration Tool > Exam tab. When enabled, /test/* refuses
# requests that don't carry the SEB request-hash header.
SEB_ENFORCE=false
SEB_BROWSER_EXAM_KEY=

# For "Send invites" auto-emailing. Dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=
